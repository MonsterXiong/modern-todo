{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Modern TODO",
  "version": "0.1.0",
  "identifier": "com.local.modern-todo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Modern TODO",
        "width": 1240,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
